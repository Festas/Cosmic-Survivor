{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "lib": ["ES2022", "DOM", "WebWorker"],
    "skipLibCheck": true
  },
  "include": [
    "js/core/**/*.js",
    "js/render/**/*.js",
    "js/systems/stanceSystem.js",
    "js/systems/weatherSystem.js",
    "js/systems/enemyBehaviors.js",
    "js/systems/coopAura.js"
  ]
}
